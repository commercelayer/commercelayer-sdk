{
  "name": "@commercelayer/sdk",
  "version": "7.9.0",
  "main": "lib/index.cjs",
  "types": "lib/index.d.ts",
  "module": "lib/index.js",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./lib/index.d.ts",
        "default": "./lib/index.js"
      },
      "require": {
        "types": "./lib/index.d.cts",
        "default": "./lib/index.cjs"
      }
    },
    "./bundle": {
      "import": {
        "types": "./lib/bundle.d.ts",
        "default": "./lib/bundle.js"
      },
      "require": {
        "types": "./lib/bundle.d.cts",
        "default": "./lib/bundle.cjs"
      }
    }
  },
  "scripts": {
    "clean": "rm -rf ./.nyc_output ./node_modules/.cache ./coverage",
    "build": "tsup",
    "generate": "tsx gen/generator.ts",
    "generate-local": "tsx gen/generator.ts -- --local",
    "lint": "biome check --enforce-assist=true",
    "check": "biome check --enforce-assist=true --write",
    "semantic-release": "semantic-release",
    "test": "vitest",
    "test-local": "tsx test/spot.ts",
    "coverage": "vitest run --coverage",
    "release": "pnpm upgrade && pnpm lint && pnpm build && pnpm test"
  },
  "keywords": [
    "javascript",
    "ecommerce",
    "jamstack",
    "commercelayer"
  ],
  "author": "Pierluigi Viti <pierluigi@commercelayer.io>",
  "license": "MIT",
  "description": "Commerce Layer Javascript SDK",
  "files": [
    "lib/**/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@commercelayer/js-auth": "^6.7.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/debug": "^4.1.13",
    "@types/node": "^24.12.0",
    "@vitest/coverage-v8": "^3.2.4",
    "conventional-changelog-conventionalcommits": "^8.0.0",
    "dotenv": "^16.6.1",
    "json-typescript": "^1.1.2",
    "jsonapi-typescript": "^0.1.3",
    "semantic-release": "^25.0.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "repository": "github:commercelayer/commercelayer-sdk",
  "bugs": "https://github.com/commercelayer/commercelayer-sdk/issues",
  "publishConfig": {
    "access": "public"
  },
  "resolutions": {
    "ansi-regex": "5.0.1"
  }
}
